# ============================================
# VOLTHIVE BACKEND - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in YOUR values
# NEVER commit .env files to version control

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Primary MongoDB connection (Atlas Cloud)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# Local MongoDB fallback (for development)
LOCAL_MONGO_URI=mongodb://127.0.0.1:27017/Volthive_DB

# Set to 'true' if MongoDB is required for startup
DB_REQUIRED=true

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
# Example: http://localhost:3000,http://localhost:5000,https://volthive.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ============================================
# FIREBASE AUTHENTICATION
# ============================================
# Method 1: Base64-encoded Service Account JSON
# FIREBASE_SERVICE_ACCOUNT_BASE64=<base64-encoded-json>

# Method 2: Path to service account JSON file
# (Recommended for local development)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ============================================
# EXTERNAL APIs
# ============================================
# Google Maps Server API Key
GOOGLE_MAPS_API_KEY=your_google_maps_server_key_here

# ============================================
# AI SERVICE CONFIGURATION
# ============================================
# URL of the Flask AI microservice
# Local: http://localhost:5001
# Production: https://your-ai-service.com
FLASK_API_URL=http://localhost:5001

# ============================================
# LOGGING & DEBUG
# ============================================
LOG_LEVEL=debug
DEBUG_MODE=false

# ============================================
# RATE LIMITING
# ============================================
# Maximum requests per 15 minutes
RATE_LIMIT_MAX=300
