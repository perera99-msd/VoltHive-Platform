# ============================================
# VOLTHIVE AI SERVICE - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in YOUR values
# NEVER commit .env files to version control

# ============================================
# SERVER CONFIGURATION
# ============================================
AI_PORT=5001
AI_DEBUG=false

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
# Examples: 
#   Development: http://localhost:3000,http://localhost:5000
#   Production: https://app.volthive.com,https://api.volthive.com
AI_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# ============================================
# MODEL CONFIGURATION
# ============================================
MODEL_PATH=models/surge_model.pkl
COLUMNS_PATH=models/model_columns.pkl

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
